# Example environment variables for running AnnaSuraksha
# Copy this file to .env or export the variables in your environment.

# JWT secret used to sign tokens. MUST be at least 32 characters in production.
JWT_SECRET=ANNASURAKSHA_V5_JWT_SECRET_KEY_32CHARS_MIN

# Groq / LLM API key (optional for demo - service will fallback to deterministic explanation)
GROQ_API_KEY=YOUR_GROQ_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

# Disable demo seeding in non-dev environments
ANNASURAKSHA_SEED_DEMO=false

# Production DB example (replace for your environment)
#SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/annasuraksha
#SPRING_DATASOURCE_USERNAME=postgres
#SPRING_DATASOURCE_PASSWORD=secret

# Optional: override server port
#SERVER_PORT=8081
